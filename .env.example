# Template of every env var the app reads. Copy to .env.<NODE_ENV> for local dev
# (e.g. .env.stage) and fill in real values. .env.* files are gitignored.
#
# DEPLOYMENT (Fly.io): non-secret vars live in fly.toml [env]. The two SECRETS
# below — JWT_SECRET and SEED_PASSWORD — are NOT set here or in fly.toml; they
# come from the Fly secrets pipeline (web UI / `fly secrets set`) and are
# injected at runtime. The values here are placeholders for LOCAL dev only.

NODE_ENV=stage
PORT=3000
DB_PATH=./data/balance.stage.db
CURRENCY=USD

# --- Auth (ADR-003) ---
# false = real auth (token required). true = stage-only bypass: inject
# req.userId=1 with no token; rejected in prod by env.js.
AUTH_BYPASS=false
JWT_EXPIRES_IN=7d

# SECRETS — local dev values only. In deployment these are Fly secrets, never committed.
# Required whenever AUTH_BYPASS is not true. Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret
# Password hashed into the seeded user (user@balance.local) by `npm run seed`.
SEED_PASSWORD=changeme
