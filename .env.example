NODE_ENV=stage
PORT=3000
DB_PATH=./data/balance.stage.db
CURRENCY=USD

# Auth (ADR-003)
# AUTH_BYPASS=true injects req.userId=1 with no token (stage only; rejected in prod).
AUTH_BYPASS=true
# Required whenever AUTH_BYPASS is not true. Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Password hashed into the seeded user (user@balance.local) by `npm run seed`.
SEED_PASSWORD=changeme
